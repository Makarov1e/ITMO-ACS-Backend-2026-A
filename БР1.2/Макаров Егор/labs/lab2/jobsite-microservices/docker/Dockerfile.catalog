# Dockerfile сервиса "catalog" (порт 3002)
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --omit=dev
COPY --from=build /app/dist ./dist
ENV SERVICE=catalog
ENV PORT=3002
EXPOSE 3002
CMD ["node", "dist/bootstrap.js"]
