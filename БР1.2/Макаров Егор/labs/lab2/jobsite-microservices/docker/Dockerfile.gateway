# Dockerfile сервиса "gateway" (порт 3000)
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --omit=dev
COPY --from=build /app/dist ./dist
ENV SERVICE=gateway
ENV PORT=3000
EXPOSE 3000
CMD ["node", "dist/bootstrap.js"]
