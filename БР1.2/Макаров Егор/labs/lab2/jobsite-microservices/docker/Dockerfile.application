# Dockerfile сервиса "application" (порт 3006)
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --omit=dev
COPY --from=build /app/dist ./dist
ENV SERVICE=application
ENV PORT=3006
EXPOSE 3006
CMD ["node", "dist/bootstrap.js"]
